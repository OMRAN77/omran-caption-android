<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#0E0B1A">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/speaking_lang"
        android:textColor="#CFC9E0"
        android:layout_marginBottom="4dp" />

    <Spinner
        android:id="@+id/spinnerSpeaking"
        android:layout_width="260dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/translate_lang"
        android:textColor="#CFC9E0"
        android:layout_marginBottom="4dp" />

    <Spinner
        android:id="@+id/spinnerTranslate"
        android:layout_width="260dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btnStart"
        android:layout_width="260dp"
        android:layout_height="56dp"
        android:backgroundTint="#7C5CFF"
        android:textColor="#FFFFFF"
        android:text="@string/start_caption" />

    <Button
        android:id="@+id/btnGoPremium"
        android:layout_width="260dp"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="#00E5A0"
        android:textColor="#0E0B1A"
        android:text="@string/go_premium" />

</LinearLayout>
